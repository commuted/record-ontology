@prefix rec: <https://www.epistemic-ontology.net/record#> .
@prefix ex:  <https://www.epistemic-ontology.net/record/examples/minimal#> .

# ============================================================================
# MINIMAL 7: the cogito as a self-verifying PATTERN (no Cogito class; §11)
# Shows: SelfVerifying warrant + reflexive provenance + self-directedness.
#        The carrier is dissolved -- the cogito's support IS its provenance
#        (the act of thinking). Not a defined class, so it cannot over-capture
#        performatives (a promise shares the warrant but isn't the cogito).
# Eyeball: 1 agent + 1 record
# ============================================================================

ex:Hugo a rec:Agent .

ex:IThinkThereforeIAm a rec:Record ;
    rec:forAgent       ex:Hugo ;          # for-whom     )
    rec:directedToward ex:Hugo ;          # of-what      ) coincide on the agent
    rec:hasProvenance  ex:TheThinking ;   # whence: the act itself (reflexive)
    rec:hasWarrant     rec:SelfVerifying .  # true by the ACT, not the form

# Its support is not a substrate it HAS but the thinking it IS (provenance).
# Certifies existence ("I am"), not nature. Indubitable but barren.
ex:TheThinking a rec:Record ;
    rec:forAgent ex:Hugo ;
    rec:hasWarrant rec:SelfVerifying .
