@prefix rec: <https://www.epistemic-ontology.net/record#> .
@prefix ex:  <https://www.epistemic-ontology.net/record/examples/minimal#> .

# ============================================================================
# MINIMAL 6: the carrier DISSOLVED into provenance + locus (§11)
# Shows: there is NO Carrier class. A record's support is two attributes:
#        hasProvenance (whence) + hasLocus (where/when, agent-relative).
# Eyeball: 1 agent + 1 record (+ 2 bare support records)
# ============================================================================

ex:Gita a rec:Agent .

ex:ShoppingList a rec:Record ;
    rec:forAgent      ex:Gita ;
    rec:hasWarrant    rec:Empirical ;
    rec:hasProvenance ex:WrittenByHand ;   # whence -- the genealogy
    rec:hasLocus      ex:OnTheFridge .     # where/when -- agent-relative

# The carrier is not a separate thing; it IS the provenance + locus.
# "What carries the carrier?" halts in the self-verifying warrant (see
# minimal-cogito), not in a substrate.

ex:WrittenByHand a rec:Record .
ex:OnTheFridge   a rec:Record .
